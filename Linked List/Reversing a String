#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct node {
    char data[100];
    struct node* next;
};

void insert_end(struct node** head, char* val) {
    struct node* new = (struct node*)malloc(sizeof(struct node));
    strcpy(new->data, val);
    new->next = NULL;

    if (*head == NULL) {
        *head = new;
        return;
    }

    struct node* temp = *head;
    while (temp->next != NULL) {
        temp = temp->next;
    }
    temp->next = new;
}

void print(struct node** head) {
    struct node* ptr = *head;
    while (ptr != NULL) {
        if (ptr->next == NULL)
            printf("%s", ptr->data);
        else
            printf("%s ", ptr->data);
        ptr = ptr->next;
    }
    printf("\n");
}

void reverse(struct node** head) {
    struct node* prev = NULL;
    struct node* curr = *head;
    struct node* next = NULL;

    while (curr != NULL) {
        next = curr->next;
        curr->next = prev;
        prev = curr;
        curr = next;
    }
    *head = prev;
}

int main() {
   
    int n;
    scanf("%d", &n);

    struct node* head = NULL;

    char val[100];
    for (int i = 0; i < n; i++) {
        scanf("%s", val);
        insert_end(&head, val);
    }

    reverse(&head);
    print(&head);

    return 0;
}
