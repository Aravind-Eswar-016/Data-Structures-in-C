void del_end(struct node** head){
    if(*head == NULL){
        return ;
    }
    
    if((*head)->next == NULL){
        free(*head);
        *head = NULL;
        return;
    }
    
    struct node* temp = *head;
    while(temp->next->next != NULL){
        temp = temp->next;
    }
    free(temp->next);
    temp->next = NULL;
}
