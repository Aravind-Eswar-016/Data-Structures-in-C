void isert_end(struct node** head, int val){
    struct node* new = (struct node*) malloc(sizeof(struct node));
    new->data = val;
    new->next = NULL;
    
    if(*head == NULL){
        *head = new;
        return;
    }
    
    struct node* temp = *head;
    while(temp->next != NULL){
        temp = temp->next;
    }
    temp->next = new;
}
