#include <stdio.h>
#include <string.h>

#define MAX 10001

char stack[MAX];
int top = -1;

void push(char ch) {
    stack[++top] = ch;
}

char pop() {
    return stack[top--];
}

char peek() {
    return stack[top];
}

int isEmpty() {
    if (top == -1)
        return 1;
    else
        return 0;
}

void removeAdjDuplicates(char str[]) {
    for (int i = 0; i < strlen(str); i++) {
        if (isEmpty() == 0 && peek() == str[i]) {
            pop();
        } else {
            push(str[i]);
        }
    }
}

int main() {
    char str[MAX];

    fgets(str, sizeof(str), stdin);
    str[strcspn(str, "\n")] = '\0';

    removeAdjDuplicates(str);

    if (isEmpty() == 1) {
        printf("Empty String\n");
    } else {
        stack[top + 1] = '\0';
        printf("%s\n", stack);
    }

    return 0;
}
