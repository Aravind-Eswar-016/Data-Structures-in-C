#include<stdio.h>
#include<stdlib.h>
#include<string.h>

#define MAX 100
 int stack[MAX];
 int top = -1;

void push(int val){
    if(top < MAX - 1){
        stack[++top] = val;
    }
}

void pop(){
    if(top == -1){
        printf("Stack Underflow\n");
        return;
    }
    printf("%d\n", stack[top--]);
}

void peek(){
    if(top == -1){
        printf("Stack Underflow\n");
        return;
    }
    printf("%d\n", stack[top]);
}

void isempty(){
    if(top == -1)
        printf("true\n");
    else
        printf("false\n");
}

void size(){
    printf("%d\n", top + 1);
}

int main(){
    int n, val;
    scanf("%d",&n);

    char com[20];

    for(int i=0; i<n; i++){
        scanf("%s", com);
        if(strcmp(com, "Push")==0){
            scanf("%d",&val);
            push(val);
        }else if(strcmp(com, "Pop")==0){
            pop();
        }else if(strcmp(com, "Top")==0){
            peek();
        }else if(strcmp(com, "IsEmpty")==0){
            isempty();
        }else if(strcmp(com, "Size")==0){
            size();
        }
    }
    return 0;
}
