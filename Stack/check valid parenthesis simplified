#include <stdio.h>
#include <string.h>

#define MAX 1000

char stack[MAX];
int top = -1;

void push(char ch) {
    stack[++top] = ch;
}

char pop() {
    return stack[top--];
}

char peek() {
    return stack[top];
}

int isEmpty() {
    return top == -1;
}

int isOpening(char ch) {
    return ch == '(' || ch == '{' || ch == '[';
}

int isMatching(char open, char close) {
    return (open == '(' && close == ')') ||
           (open == '{' && close == '}') ||
           (open == '[' && close == ']');
}

int isValid(char str[]) {
    for (int i = 0; i < strlen(str); i++) {
        char ch = str[i];

        if (isOpening(ch)) {
            push(ch);
        } else {
            if (isEmpty()) {
                return 0;
            }
            if (!isMatching(pop(), ch)) {
                return 0;
            }
        }
    }
    return isEmpty();
}

int main() {
    char str[MAX];
    scanf("%s", str);

    if (isValid(str))
        printf("true");
    else
        printf("false");

    return 0;
}
