#include<stdio.h>
#include<string.h>

#define MAX 100

char stack[MAX];
int top = -1;

void push(char ch){
    stack[++top] = ch;
}

char pop(){
    return stack[top--];
}

int isempty(){
   if(top == -1)
    return 1;
   else 
    return 0;
}

int isOpen(char ch){
    if(ch == '(' || ch == '{' || ch == '[')
        return 1;
    else 
        return 0;
}

int isMatch(char open, char close){
    if(open == '(' && close == ')'){
        return 1;
    }else if(open == '{' && close == '}'){
        return 1;
    }else if(open == '[' && close == ']'){
        return 1;
    }else{
        return 0;
    }
}

int isValid(char str[]){
    for(int i=0; i<strlen(str); i++){
        if(isOpen(str[i])){
            push(str[i]);
        }else{
            if(isempty()){
                return 0;
            }
            if(isMatch(pop(),str[i])){
            
            }else{
                return 0;
            }
        }
    }
    
    if(isempty())
        return 1;
    else
        return 0;
}

int main(){
    char str[100];
    scanf("%s", str);
    
    if(isValid(str))
        printf("true");
    else
        printf("false");
        
    return 0;
}
